// QuitaZAP - Schema Prisma
// Banco: PostgreSQL (Supabase)

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────
// CLIENTE
// ─────────────────────────────────────────
// statusAtendimento: NOVO | AGUARDANDO_INFORMACOES | PLANO_GERADO | ACOMPANHAMENTO | ENCERRADO
model Cliente {
  id                    String   @id @default(cuid())
  nome                  String
  telefone              String
  cpf                   String?
  email                 String?
  obs                   String?
  statusAtendimento     String   @default("NOVO")
  rendaMensal           Float?
  despesasFixas         Float?
  valorDisponivelMensal Float?
  gratuito              Boolean   @default(false)
  assinaturaVenceEm     DateTime?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime @updatedAt

  dividas        Divida[]
  pagamentos     Pagamento[]
  planosEnviados PlanoEnviado[]
  botSessoes     BotSessao[]
  cobrancas      Cobranca[]
}

// ─────────────────────────────────────────
// DÍVIDA
// ─────────────────────────────────────────
// tipo:      CARTAO | EMPRESTIMO | BOLETO | ACORDO | OUTRO
// status:    ATIVA  | QUITADA    | NEGOCIANDO
// prioridade: 1 = mais urgente, 0 = sem prioridade definida
model Divida {
  id             String    @id @default(cuid())
  clienteId      String
  credor         String
  descricao      String?
  obs            String?
  valorTotal     Float
  valorPago      Float     @default(0)
  tipo           String    @default("OUTRO")
  status         String    @default("ATIVA")
  prioridade     Int       @default(0)
  diaVencimento  Int?
  emAtraso       Boolean   @default(false)
  diasAtraso     Int?
  dataReferencia DateTime?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  parcelas   Parcela[]
  pagamentos Pagamento[]
}

// ─────────────────────────────────────────
// PARCELA
// ─────────────────────────────────────────
// status: PENDENTE | PAGA | VENCIDA | CANCELADA
model Parcela {
  id           String   @id @default(cuid())
  dividaId     String
  numero       Int
  valor        Float
  vencimento   DateTime
  status       String   @default("PENDENTE")
  obs          String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  divida Divida @relation(fields: [dividaId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// PAGAMENTO
// ─────────────────────────────────────────
model Pagamento {
  id           String   @id @default(cuid())
  dividaId     String
  clienteId    String
  valor        Float
  data         DateTime
  obs          String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  divida  Divida  @relation(fields: [dividaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// PLANO ENVIADO
// ─────────────────────────────────────────
model PlanoEnviado {
  id        String   @id @default(cuid())
  clienteId String
  texto     String
  criadoEm  DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// BOT SESSAO (conversa WhatsApp)
// ─────────────────────────────────────────
// etapa: COLETANDO_DIVIDAS | AGUARDANDO_RENDA | PLANO_GERADO
model BotSessao {
  id           String   @id @default(cuid())
  telefone     String   @unique
  clienteId    String?
  etapa        String   @default("COLETANDO_DIVIDAS")
  nome         String?
  dividasTemp  String   @default("[]") // JSON: [{texto, valor, parcelas}]
  renda        Float?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// LEAD DE VENDAS (funil Instagram/Facebook)
// ─────────────────────────────────────────
// etapa: QUALIFICACAO | PROVA | OFERTA | FOLLOWUP | CONVERTIDO | DESISTIU
model LeadVendas {
  id           String   @id @default(cuid())
  telefone     String   @unique
  nome         String?
  etapa        String   @default("QUALIFICACAO")
  cupomEnviado Boolean  @default(false)
  msgCount     Int      @default(0)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ─────────────────────────────────────────
// COBRANÇA (Cobrador Automático Pessoal)
// ─────────────────────────────────────────
// status: PENDENTE | ENVIADA | PAGA | CANCELADA
// etapa:  1=amigável, 2=firme, 3=última chance
model Cobranca {
  id           String    @id @default(cuid())
  clienteId    String
  credorNome   String    // nome do assinante que cobra (ex: "Ibrahim")
  devedorNome  String    // nome de quem deve
  devedorFone  String    // whatsapp de quem deve (com DDI)
  valor        Float
  vencimento   DateTime
  mensagem     String?   // mensagem personalizada do credor
  pixChave     String?   // chave pix do credor (default: telefone do credor)
  status       String    @default("PENDENTE")
  etapa        Int       @default(1)
  tentativas   Int       @default(0)
  ultimoEnvio  DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ═════════════════════════════════════════
// QUITAZAP RECEBER — Modelos novos (multi-tenant)
// Sistema separado dos modelos legados acima
// ═════════════════════════════════════════

// ─────────────────────────────────────────
// USUARIO (dono da conta QuitaZAP Receber)
// ─────────────────────────────────────────
model Usuario {
  id                String    @id @default(cuid())
  nome              String
  email             String    @unique
  senhaHash         String
  telefone          String?
  // Plano: GRATUITO | RECEBER_BASICO | RECEBER_PRO | RECEBER_PREMIUM | CONTROLE
  plano             String    @default("GRATUITO")
  planoPago         Boolean   @default(false)
  assinaturaId      String?
  assinaturaVenceEm DateTime?
  gratuito          Boolean   @default(false)
  // WhatsApp Business
  wpInstancia       String?
  wpConectado       Boolean   @default(false)
  wpTelefone        String?
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt

  contatos      ContatoReceber[]
  pendencias    Pendencia[]
  configuracoes ConfigUsuario?
  enviosBot     EnvioBot[]
}

// ─────────────────────────────────────────
// CONTATO (pagador/devedor do usuário)
// ─────────────────────────────────────────
model ContatoReceber {
  id         String      @id @default(cuid())
  usuarioId  String
  nome       String
  telefone   String
  email      String?
  documento  String?
  obs        String?
  criadoEm   DateTime    @default(now())

  usuario    Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pendencias Pendencia[]

  @@unique([usuarioId, telefone])
}

// ─────────────────────────────────────────
// PENDÊNCIA (cobrança/lembrete de pagamento)
// ─────────────────────────────────────────
model Pendencia {
  id             String    @id @default(cuid())
  usuarioId      String
  contatoId      String?
  // Dados
  descricao      String
  // tipo: VENDA_FIADA | SERVICO | PARCELA | MENSALIDADE | ALUGUEL | OUTRO
  tipo           String    @default("OUTRO")
  valor          Float
  vencimento     DateTime
  // Pagamento
  // formaPagto: PIX_CHAVE | PIX_QR | PIX_LINK | MANUAL | SEM_PAGAMENTO_ONLINE
  formaPagto     String?
  pixChave       String?
  linkSlug       String?   @unique
  // Status: RASCUNHO | AGENDADA | ENVIADA | ENTREGUE | LIDA | LINK_ABERTO
  //         | RESPONDIDA | AGUARDANDO_PAGAMENTO | PAGAMENTO_INICIADO
  //         | PAGA | PARCIALMENTE_PAGA | VENCIDA | PAUSADA | CANCELADA | FALHOU
  status         String    @default("RASCUNHO")
  etapa          Int       @default(1)
  tentativas     Int       @default(0)
  enviarEm       DateTime?
  ultimoEnvio    DateTime?
  reguaPausada   Boolean   @default(false)
  // Pagamento registrado
  valorPago      Float?
  pagoEm         DateTime?
  comprovante    String?
  confirmacaoManual Boolean @default(false)
  // Mensagem personalizada
  mensagemCustom String?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  usuario  Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contato  ContatoReceber? @relation(fields: [contatoId], references: [id], onDelete: SetNull)
  envios   EnvioBot[]
}

// ─────────────────────────────────────────
// ENVIO BOT (cada mensagem enviada)
// ─────────────────────────────────────────
model EnvioBot {
  id          String    @id @default(cuid())
  usuarioId   String
  pendenciaId String
  etapa       Int
  mensagem    String
  enviadoEm   DateTime  @default(now())
  // status: ENVIADO | ENTREGUE | LIDO | RESPONDIDO | FALHOU
  status      String    @default("ENVIADO")
  resposta    String?

  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pendencia Pendencia @relation(fields: [pendenciaId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CONFIGURAÇÕES DO USUÁRIO
// ─────────────────────────────────────────
model ConfigUsuario {
  id             String  @id @default(cuid())
  usuarioId      String  @unique
  nomeNegocio    String?
  horarioEnvio   String  @default("08:00")
  fusoHorario    String  @default("America/Bahia")
  resumoDiario   Boolean @default(true)
  resumoSemanal  Boolean @default(true)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// LOG DE CONSUMO DE IA
// ─────────────────────────────────────────
model LogIA {
  id          String   @id @default(cuid())
  clienteId   String?
  gratuito    Boolean  @default(false)
  tipo        String   // "chat" | "whisper" | "vision"
  tokensInput Int      @default(0)
  tokensOutput Int     @default(0)
  custoUSD    Float    @default(0)
  criadoEm   DateTime @default(now())
}
